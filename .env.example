# ===== SUPABASE =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===== JWT =====
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# ===== NETSUITE OAUTH 1.0a =====
# Account & Environment
NETSUITE_ACCOUNT_ID=sandbox_account_id_or_production_id
NETSUITE_REALM=sandbox
NETSUITE_ENVIRONMENT=sandbox
NETSUITE_API_VERSION=2022.1

# OAuth 1.0a Consumer Credentials (Integration Record)
NETSUITE_CONSUMER_KEY=your_consumer_key_here
NETSUITE_CONSUMER_SECRET=your_consumer_secret_here

# OAuth 1.0a Token Credentials (Token-based Auth)
NETSUITE_TOKEN_ID=your_token_id_here
NETSUITE_TOKEN_SECRET=your_token_secret_here

# ===== NETSUITE FILE CABINET =====
# Configuración de carpetas y archivos en File Cabinet
NETSUITE_FILECABINET_SIGNATURES_FOLDER_ID=123
NETSUITE_FILECABINET_PATH_PREFIX=/Firmas
NETSUITE_FILECABINET_SIGNATURE_FOLDER_PATTERN={LOCATION}/{TYPE}
NETSUITE_FILECABINET_FILE_PATTERN={IF}_{TYPE}.png

# ===== NETSUITE BÚSQUEDAS GUARDADAS =====
# ID de búsqueda guardada para obtener IFs disponibles
NETSUITE_SAVED_SEARCH_ID_IFS=customsearch_wms_ifs

# ===== SERVER CONFIG =====
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost,http://localhost:3001,http://localhost:80

# ===== LOGGING =====
LOG_LEVEL=info
