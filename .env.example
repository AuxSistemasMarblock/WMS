# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# NetSuite
NETSUITE_ACCOUNT_ID=your_account_id
NETSUITE_CLIENT_ID=your_client_id
NETSUITE_CLIENT_SECRET=your_client_secret
NETSUITE_REDIRECT_URI=http://localhost:3001/auth/netsuite/callback

# Servidor
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# Búsqueda guardada NetSuite (ID de búsqueda guardada para IFs)
NETSUITE_SAVED_SEARCH_ID_IFS=customsearch_id_goes_here
